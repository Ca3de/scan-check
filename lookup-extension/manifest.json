{
  "manifest_version": 3,
  "name": "FC AA Lookup",
  "version": "1.1.0",
  "description": "Look up Amazon FC associates by Login, Badge, Employee ID, or Name. Single lookups and CSV batch enrichment.",
  "author": "Ca3de",
  "homepage_url": "https://github.com/Ca3de/scan-check",

  "browser_specific_settings": {
    "gecko": {
      "id": "fc-aa-lookup@ca3de.github.io",
      "strict_min_version": "139.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "permissions": [
    "storage",
    "tabs",
    "scripting"
  ],

  "host_permissions": [
    "*://fclm-portal.amazon.com/*"
  ],

  "background": {
    "service_worker": "background/background.js",
    "scripts": ["background/background.js"]
  },

  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    },
    "default_title": "FC AA Lookup"
  },

  "side_panel": {
    "default_path": "sidebar/sidebar.html"
  },

  "sidebar_action": {
    "default_title": "FC AA Lookup",
    "default_panel": "sidebar/sidebar.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },

  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
